@model HealthTracker.Models.ApplicationUser

@{
    ViewData["Title"] = "My Profile";
}

<h2 class="mb-4">My Profile</h2>

<div class="card shadow-sm p-4">

    <!-- Profile Photo Display -->
    @if (!string.IsNullOrEmpty(Model.ProfilePhotoPath))
    {
        <div class="text-center mb-3">
            <img src="@Model.ProfilePhotoPath"
                 width="160"
                 height="160"
                 class="rounded-circle border shadow-sm"
                 style="object-fit:cover;" />
        </div>
    }
    else
    {
        <p class="text-muted text-center">
            No profile photo uploaded yet.
        </p>
    }

    <!-- Upload Error -->
    @if (TempData["UploadError"] != null)
    {
        <div class="alert alert-danger">
            @TempData["UploadError"]
        </div>
    }

    <!-- Upload Success -->
    @if (TempData["UploadSuccess"] != null)
    {
        <div class="alert alert-success">
            @TempData["UploadSuccess"]
        </div>
    }

    <!-- Upload Form -->
    <form asp-controller="Home"
          asp-action="UploadPhoto"
          method="post"
          enctype="multipart/form-data"
          class="mb-4">

        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label class="form-label">Upload Profile Photo</label>
            <input type="file"
                   name="photo"
                   class="form-control"
                   accept="image/*"
                   required />
        </div>

        <button type="submit" class="btn btn-primary">
            Upload Photo
        </button>
    </form>

    <hr />

    <!-- Profile Details -->
    <div class="mt-3">
        <p><strong>First Name:</strong> @Model.FirstName</p>
        <p><strong>Last Name:</strong> @Model.LastName</p>
        <p><strong>Email:</strong> @Model.Email</p>
    </div>

    <a asp-controller="Home"
       asp-action="EditProfile"
       class="btn btn-outline-secondary btn-sm me-2">
        Edit Profile
    </a>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }

    <a asp-controller="Home"
       asp-action="ChangePassword"
       class="btn btn-outline-dark btn-sm">
        Change Password
    </a>

</div>